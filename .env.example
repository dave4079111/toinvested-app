# ToInvested.com Environment Configuration
# Copy this file to .env and fill in your values

# Server
PORT=3000
NODE_ENV=production
BASE_URL=https://toinvested.com

# JWT Secret (REQUIRED - generate a random 64-char string)
# App will not start without this value
JWT_SECRET=change-this-to-a-random-64-character-string

# CORS Allowed Origins (comma-separated)
CORS_ORIGINS=https://toinvested.com,https://www.toinvested.com

# Stripe (get from https://dashboard.stripe.com)
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Stripe Price IDs (create in Stripe Dashboard > Products)
# Wealth Builder: $49.99 one-time payment
STRIPE_PRICE_WB_ONETIME=price_your_wb_onetime_id
# Wealth Builder Yearly: $999/year subscription (3-day free trial)
STRIPE_PRICE_WB_YEARLY=price_your_wb_yearly_id

# Email (SMTP settings for transactional emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@toinvested.com

# Admin credentials (REQUIRED for admin account creation)
# No default admin will be created if ADMIN_PASSWORD is not set
ADMIN_EMAIL=admin@toinvested.com
ADMIN_PASSWORD=change-this-to-a-strong-password

# Anthropic API Key (REQUIRED for AI-powered analyzers)
# Get from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Self-healing config
HEALTH_CHECK_INTERVAL=60000
AUTO_RESTART_ON_FAILURE=true
MAX_RESTART_ATTEMPTS=5
